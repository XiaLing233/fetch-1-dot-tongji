# fetch-1-dot-tongji 配置模板
# cp .env.example .env 然后填入真实值

# === MariaDB ===
DB_HOST=mariadb
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=tongjinoti

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379

# === JWT & Session ===
JWT_SECRET_KEY=your_jwt_secret_key
FLASK_SESSION_SECRET=your_session_secret

# === RSA 私钥 & AES ===
RSA_PRIVATE_KEY_PATH=keys/web_login_pri.pem
AES_KEY=your_aes_key
AES_IV=your_aes_iv

# === SMTP（验证/找回密码 — 个人账号） ===
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_NICKNAME=琪露诺bot

# === SMTP（通知推送 — 批量账号） ===
SMTP_USER_BATCH=notify@example.com
SMTP_PASS_BATCH=your_batch_smtp_password

# === IMAP（QQ邮箱验证码接收） ===
IMAP_SERVER=imap.qq.com
IMAP_PORT=993
IMAP_EMAIL=your_qq_email@qq.com
IMAP_GRANTCODE=qq邮箱授权码

# === 腾讯云 COS ===
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BUCKET=your_bucket_name
COS_REGION=ap-tokyo
COS_DOMAIN=static.example.com

# === 同济账号（爬虫登录 1.tongji.edu.cn） ===
TJ_SNO=你的学号
TJ_PASSWD=你的密码

# === 爬虫开关 ===
SEND_EMAIL_ENABLED=false
STORE_PATH=./1dot
IMG_PATH=./data/background

# === Flask ===
PRODUCTION=true
